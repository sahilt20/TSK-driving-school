# Production Environment Variables for Netlify Deployment
# Copy this file to Netlify Environment Variables settings

# ===== REQUIRED - Supabase Configuration =====
# Get these from: https://app.supabase.com -> Your Project -> Settings -> API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ===== OPTIONAL - Production Settings =====

# Node Environment (set automatically by Netlify)
# NODE_ENV=production

# Disable Next.js Telemetry (already set in netlify.toml)
# NEXT_TELEMETRY_DISABLED=1

# ===== NOTES =====
#
# 1. DO NOT commit this file with real values
# 2. Set these in Netlify Dashboard -> Site settings -> Environment variables
# 3. All variables starting with NEXT_PUBLIC_ are exposed to the browser
# 4. Rebuild required after changing environment variables
#
# For detailed setup instructions, see:
# - NETLIFY_DEPLOYMENT.md
# - QUICK_SUPABASE_SETUP.md
